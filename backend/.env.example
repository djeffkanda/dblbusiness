# Application Tier — Express API
# Deploy on private EC2 instance (AWS application tier)

PORT=3200

# Data tier connection (use data-tier in dev container, private IP on AWS)
DB_HOST=data-tier
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=apppass
DB_NAME=bldbusiness

# CORS — presentation tier origin
CORS_ORIGIN=http://localhost:5173

# JWT secret for authentication (change in production)
JWT_SECRET=change-me-to-a-long-random-string
